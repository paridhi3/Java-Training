			}
		}
		
		System.out.println("Product name: "+name+" not found");
	}
	
	public void checkout() {
		double totalBill = 0;
		
		for(product prod:cart) {
			totalBill += prod.prodPrice; 
		}
		
		System.out.println("Total price to be paid: Rs "+totalBill);
