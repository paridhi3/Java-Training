		System.out.println("Checkout complete. Cart is empty.");
	}
	
	public void display() {
		if(cart.isEmpty()==true) {
			System.out.println("Cart is empty.");
		}
		else {
			for(product prod:cart) {
				prod.toString(); 
			}
		}
	}
	
	public void menu() {
		while(true) {
