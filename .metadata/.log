package JavaBasicsPkg;

import java.util.Scanner;

public class whileFactorial {
	public static void main (String[] args) {
			
			Scanner sc = new Scanner(System.in);
			
			System.out.println("Enter a number: ");
			int n = sc.nextInt();
			
			if(n>0)
			{
				int result = 1, i=1;
		        (i <= n; i++) {
		            result *= i;
