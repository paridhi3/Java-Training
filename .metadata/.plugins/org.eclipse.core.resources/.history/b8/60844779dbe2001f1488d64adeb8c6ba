package oops;

public class fullTimeEmployee extends Employee{

	public fullTimeEmployee(String empName, int empID, String empDept) {
		super(empName, empID, empDept);
	}
	
	@Override
	double calSalary() {
		return basicSalary+bonus;
	}
 
	public static void main(String[] args)
	{
		fullTimeEmployee fe =new fullTimeEmployee("paridhi", 1, "IT");
		fe.displayEmpDetails();
	}

}
