package JavaBasicsPkg;

import java.util.Scanner;

public class ExceptionHandling {
	System.out.println("Enter a and b: ");
	int a,b;
	Scanner sc = new Scanner(System.in);
	try {
		int result = a/b;
	}
	catch(Exception e) {
		System.out.println(e.getMessage());
	}
	finally {
		System.out.println("-----------------");
	}
}
