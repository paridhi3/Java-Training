<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    
    <!-- Address bean using setter injection -->
    <bean id="address" class="com.ems.EMS.model.Address.java">
    	<property name="street" value="main street"></property>
    	<property name="city" value="london"></property>
    	<property name="state" value="UP"></property>
    	<property name="zipCode" value="123456"></property>
    </bean>

</beans>

